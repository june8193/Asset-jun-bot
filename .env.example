# Telegram Bot API Token (from @BotFather)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# Allowed Telegram User ID(s) (comma-separated list, e.g., "12345678,98765432")
# Only these users will be allowed to interact with the bot.
TELEGRAM_ALLOWED_USER_IDS="your_telegram_user_id_here"

# Google Gemini API Key (for Antigravity SDK)
GEMINI_API_KEY="your_gemini_api_key_here"

# AssetManager API base URL
# Default is http://localhost:8000
ASSET_MANAGER_API_URL="http://localhost:8000"

# Storage Base Directory (where logs, and future reports will be stored)
STORAGE_DIR="your_storage_directory_path_here"

